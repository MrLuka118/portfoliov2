# ---------------------------------------------------------------------------
# Luka Photography — primer okoljskih spremenljivk.
# Kopiraj v `.env` (`cp .env.example .env`) in izpolni vrednosti.
# ---------------------------------------------------------------------------

# Postgres baza (Neon). Pri Neonu uporabi "Pooled connection" za DATABASE_URL.
# Primer: postgresql://user:pass@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Direktna (ne-pooled) povezava za migracije – pri Neonu host brez "-pooler".
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# NextAuth – skrivnost za podpisovanje sej. Generiraj: `openssl rand -base64 32`
NEXTAUTH_SECRET="zamenjaj-z-naključno-vrednostjo"
# URL aplikacije. Lokalno: http://localhost:3000 ; na produkciji domena (Vercel ga nastavi sam).
NEXTAUTH_URL="http://localhost:3000"

# Vercel Blob – token za nalaganje slik.
# Dobiš ga v Vercel Dashboard → Storage → Blob → ".env.local" (Read/Write token).
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# Začetni admin uporabnik (uporabi prisma seed za ustvarjanje).
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="zamenjaj-me-z-močnim-geslom"
